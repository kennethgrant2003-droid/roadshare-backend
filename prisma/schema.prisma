generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  helper
  admin
}

model User {
  id        String   @id @default(uuid())
  role      Role     @default(customer)
  phone     String   @unique
  email     String?
  fullName  String?
  createdAt DateTime @default(now())

  helper Helper?

  jobsAsCustomer Job[]
  jobsAsHelper   Job[] @relation("JobHelper")
}

model Helper {
  id              String   @id @default(uuid())
  userId          String   @unique
  isApproved      Boolean  @default(false)
  isOnline        Boolean  @default(false)
  latitude        Float?
  longitude       Float?
  maxRadiusMiles  Float    @default(15)
  stripeAccountId String?
  rating          Float    @default(5.0)

  user User @relation(fields: [userId], references: [id])
}

model Job {
  id              String   @id @default(uuid())
  customerId      String
  helperId        String?
  serviceType     String
  status          String   @default("searching")

  pickupLat       Float
  pickupLng       Float

  price           Float
  platformFee     Float
  helperPayout    Float

  paymentIntentId String?

  acceptedAt      DateTime?
  enRouteAt       DateTime?
  arrivedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelledBy     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime? @updatedAt

  customer User  @relation(fields: [customerId], references: [id])
  helper   User? @relation("JobHelper", fields: [helperId], references: [id])
}